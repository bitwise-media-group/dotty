# Signing config for profile {{.ProfileName}}, rendered by `dotty init` and
# included by the shared git config through the active-profile symlink.
{{- if .SecurityKeys }}

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
	defaultKeyCommand = "dotty signing-key get --format=key"
	program = dotty
{{- end }}
